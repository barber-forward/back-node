@baseUrl = http://localhost:3333/api

@authToken = 

@refreshToken = 

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "diego@rocketseat.com.br",
  "password": "123456"
}

### Login do barbeiro
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "joao@barbearia.com",
  "password": "123456"
}

### Refresh Token
POST {{baseUrl}}/auth/refresh
Cookie: refresh_token={{refreshToken}}

### Cadastro de usuário
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Diego Fernandes",
  "email": "diego@rocketseat.com.br",
  "password": "123456"
}

### Cadastro de barbeiro
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Barbearia do João",
  "email": "joao@barbearia.com",
  "password": "123456"
}

### Atualizar perfil
PATCH {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
"name": "João Fernandes"
}

### Perfil do usuário
GET {{baseUrl}}/users/me
Content-Type: application/json
Authorization: Bearer {{authToken}}

### ============================================================
### BARBEARIAS
### ============================================================

@barbershopId = 

### Criar barbearia
POST {{baseUrl}}/barbershops
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Barbearia do Lucas",
  "phone": "11999999998",
  "address": "Rua B, 123",
  "city": "Brasília",
  "state": "DF",
  "description": "Descrição opcional",
  "email": "contato@example.com",
  "avatar": "https://i.pravatar.cc/150?img=3",
  "zipCode": "01234-567",
  "latitude": -23.55052,
  "longitude": -46.633308
}

### Atualizar barbearia
PATCH {{baseUrl}}/barbershops/{{barbershopId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "address": "Rua A, 1234"
}

### Buscar barbearia
GET {{baseUrl}}/barbershops/{{barbershopId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

### Listar barbearias (com paginação)
GET {{baseUrl}}/barbershops?page=1&pageSize=10
Content-Type: application/json
Authorization: Bearer {{authToken}}

### Listar barbearias (filtros + paginação)
GET {{baseUrl}}/barbershops?city=Brasília&state=DF&isActive=true&page=1&pageSize=10
Content-Type: application/json
Authorization: Bearer {{authToken}}

### Deletar barbearia
DELETE {{baseUrl}}/barbershops/{{barbershopId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

### ============================================================
### SERVIÇOS
### ============================================================

@serviceId = 

### Criar serviço
POST {{baseUrl}}/services
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "name": "Corte masculino",
  "description": "Corte social ou degradê",
  "price": 35.00,
  "duration": 30,
  "imageUrl": "https://i.pravatar.cc/150?img=10"
}

### Listar serviços do barbeiro
GET {{baseUrl}}/services
Content-Type: application/json
Authorization: Bearer {{authToken}}

### Atualizar serviço
PATCH {{baseUrl}}/services/{{serviceId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "price": 35
}

### Deletar serviço
DELETE {{baseUrl}}/services/{{serviceId}}
Content-Type: application/json
Authorization: Bearer {{authToken}}

@businessHourId = 

### ============================================================
### HORÁRIOS DE FUNCIONAMENTO
### ============================================================

### Listar horários
GET {{baseUrl}}/business-hours
Content-Type: application/json
Authorization: Bearer {{authToken}}

### Salvar todos os horários (upsert completo — todos os dias da semana)
PATCH {{baseUrl}}/business-hours
Content-Type: application/json
Authorization: Bearer {{authToken}}

[
  { "dayOfWeek": "SUNDAY",    "openTime": "00:00", "closeTime": "00:00", "isClosed": true  },
  { "dayOfWeek": "MONDAY",    "openTime": "08:00", "closeTime": "20:00", "isClosed": false },
  { "dayOfWeek": "TUESDAY",   "openTime": "08:00", "closeTime": "20:00", "isClosed": false },
  { "dayOfWeek": "WEDNESDAY", "openTime": "08:00", "closeTime": "20:00", "isClosed": false },
  { "dayOfWeek": "THURSDAY",  "openTime": "08:00", "closeTime": "20:00", "isClosed": false },
  { "dayOfWeek": "FRIDAY",    "openTime": "08:00", "closeTime": "20:00", "isClosed": false },
  { "dayOfWeek": "SATURDAY",  "openTime": "09:00", "closeTime": "18:00", "isClosed": false }
]

### Atualizar apenas segunda-feira
PATCH {{baseUrl}}/business-hours
Content-Type: application/json
Authorization: Bearer {{authToken}}

[
  { "dayOfWeek": "MONDAY", "openTime": "09:00", "closeTime": "19:00", "isClosed": false }
]

### Fechar domingo (toggle isClosed)
PATCH {{baseUrl}}/business-hours
Content-Type: application/json
Authorization: Bearer {{authToken}}

[
  { "dayOfWeek": "SUNDAY", "openTime": "00:00", "closeTime": "00:00", "isClosed": true }
]
