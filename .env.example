# Database
DATABASE_URL="postgresql://user:password@localhost:5432/barberforward"

# JWT Keys (generate with openssl)
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
# Convert to base64: cat private.pem | base64 -w 0
JWT_PRIVATE_KEY="your_base64_private_key"
JWT_PUBLIC_KEY="your_base64_public_key"

# Server
PORT=3333

# Google OAuth (Get from https://console.cloud.google.com/)
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"
# GOOGLE_CALLBACK_URL="http://localhost:3333/auth/google/callback"
